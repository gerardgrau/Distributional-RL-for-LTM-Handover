# Python
__pycache__/
*.py[cod]
*$py.class
/venv/
/venv-RL/
/.env
/.venv/

# IDEs
/.vscode/
/.idea/
/.DS_Store

/conductor

# Local-only material — kept on disk for development, intentionally NOT published.
# The research journal (meetings, planning, studies, experiment logs) and the
# collaborator reference code stay private to this working copy.
/notes/
/docs/reference/ltm_ho_reference.py
/docs/reference/ltm_ho_reference_matlab.txt
/docs/CMAB for LTM HO.md

# Per-run operational logs (overnight queues, parity-check stdout, etc.)
/logs/

# Presentation-prep figures/animations (local working material, ~77 MB of MP4s).
# The reproducible source figures live in results/ and paper/; this folder is a
# curated copy for talks. Remove this line if you want to publish it.
/figures/

# LaTeX intermediate build artifacts (paper.pdf is tracked; these byproducts are not)
/paper/*.aux
/paper/*.log
/paper/*.out
/paper/*.bbl
/paper/*.blg
/paper/*.synctex.gz

